---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostCard from '../../components/PostCard.astro';
import TagFilter from '../../components/TagFilter.astro';
import { SITE_DESCRIPTION, SITE_TITLE, collectTags } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const tags = collectTags(posts);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`글 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: var(--maxw-wide);
			}
			.page-head {
				margin-bottom: 1.6em;
			}
			.page-head h1 {
				margin: 0 0 0.2em;
				font-size: 2.1rem;
			}
			.page-head p {
				margin: 0;
				color: rgb(var(--gray));
			}
			.post-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
			}
			.post-list > li {
				padding: 2.6em 0;
				border-top: 1px solid rgb(var(--gray-light));
			}
			.post-list > li:first-child {
				padding-top: 0.5em;
				border-top: none;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-head">
				<h1>글</h1>
				<p>{SITE_DESCRIPTION}</p>
			</div>
			<TagFilter tags={tags} total={posts.length} active="all" />
			<ul class="post-list">
				{
					posts.map((post) => (
						<li>
							<PostCard post={post} />
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
