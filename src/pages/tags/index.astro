---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE, collectTags, withBase } from '../../consts';

const posts = await getCollection('blog');
const tags = collectTags(posts);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`태그 · ${SITE_TITLE}`} description="모든 태그와 글 개수." />
		<style>
			main {
				width: var(--maxw-wide);
			}
			.page-head {
				margin-bottom: 2em;
			}
			.page-head h1 {
				margin: 0 0 0.2em;
				font-size: 2.1rem;
			}
			.page-head p {
				margin: 0;
				color: rgb(var(--gray));
			}
			.tag-cloud {
				display: flex;
				flex-wrap: wrap;
				gap: 0.7em;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.tag-cloud .tag-chip {
				font-size: 0.95rem;
				padding: 0.4em 1em;
			}
			.empty {
				color: rgb(var(--gray));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-head">
				<h1>태그</h1>
				<p>주제별로 글을 모아 봅니다.</p>
			</div>
			{
				tags.length > 0 ? (
					<ul class="tag-cloud">
						{tags.map((t) => (
							<li>
								<a class="tag-chip" href={withBase(`/tags/${t.slug}/`)}>
									<span aria-hidden="true">#</span>
									{t.tag} <span class="count">{t.count}</span>
								</a>
							</li>
						))}
					</ul>
				) : (
					<p class="empty">아직 태그가 없습니다.</p>
				)
			}
		</main>
		<Footer />
	</body>
</html>
