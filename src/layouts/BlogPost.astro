---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TagList from '../components/TagList.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<style>
			main {
				width: var(--maxw-wide);
			}
			article {
				padding-bottom: 2em;
			}

			/* ── Overlay (magazine) hero — posts with a heroImage ── */
			.hero-banner {
				position: relative;
				width: 100%;
				max-width: none; /* 좌우 여백 없이 화면 꽉 차게(full-bleed) */
				margin: 0;
				height: clamp(240px, 32vw, 380px);
				overflow: hidden;
				background: rgb(var(--surface-2));
			}
			.hero-banner :global(img) {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}
			.hero-scrim {
				position: absolute;
				inset: 0;
				/* 이미지 전체를 은은하게 딤(투명도) + 하단은 조금 더 어둡게 → 제목이 이미지에 겹쳐 보이도록 */
				background:
					linear-gradient(to top, rgba(0, 0, 0, 0.45) 0%, rgba(0, 0, 0, 0.22) 55%, rgba(0, 0, 0, 0.14) 100%),
					rgba(0, 0, 0, 0.12);
			}
			.hero-overlay {
				position: absolute;
				inset: 0;
				display: flex;
				align-items: center;
			}
			.hero-inner {
				width: 100%;
				max-width: var(--maxw-wide);
				margin: 0 auto;
				padding: 2.2em 1.25em;
				color: #fff;
			}
			.hero-inner .meta {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				font-size: 0.85rem;
				letter-spacing: 0.02em;
				color: rgba(255, 255, 255, 0.85);
				margin-bottom: 0.6em;
				text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
			}
			.hero-inner .meta .dot {
				width: 4px;
				height: 4px;
				border-radius: 50%;
				background: rgba(255, 255, 255, 0.75);
			}
			.hero-inner .last-updated-on {
				font-style: italic;
			}
			.hero-inner h1 {
				margin: 0;
				color: #fff;
				font-size: clamp(1.75rem, 4.6vw, 2.85rem);
				line-height: 1.22;
				letter-spacing: -0.02em;
				text-shadow: 0 2px 14px rgba(0, 0, 0, 0.45);
			}
			.hero-inner .tags {
				margin-top: 1em;
			}
			/* tag chips over the dark scrim */
			.hero-inner :global(.tag-chip) {
				color: #fff;
				background: rgba(255, 255, 255, 0.16);
				border-color: rgba(255, 255, 255, 0.5);
				backdrop-filter: blur(3px);
				-webkit-backdrop-filter: blur(3px);
			}
			.hero-inner :global(.tag-chip:hover) {
				color: #fff;
				background: rgba(255, 255, 255, 0.3);
				border-color: rgba(255, 255, 255, 0.75);
			}

			.lead {
				max-width: var(--maxw-prose);
				margin: 0 auto 0.5em;
				color: rgb(var(--gray));
				font-size: 1.1rem;
				line-height: 1.75;
			}

			/* ── Plain (no hero) header — white, no overlay ── */
			.title {
				margin-bottom: 2em;
			}
			.title .meta {
				display: inline-flex;
				align-items: center;
				gap: 0.5em;
				font-size: 0.85rem;
				letter-spacing: 0.02em;
				color: rgb(var(--gray));
				margin-bottom: 0.6em;
			}
			.title .meta .dot {
				width: 4px;
				height: 4px;
				border-radius: 50%;
				background: rgb(var(--gray));
			}
			.title .last-updated-on {
				font-style: italic;
			}
			.title h1 {
				margin: 0 0 0.5em;
				line-height: 1.25;
			}
			.title .description {
				margin: 0 0 1em;
				color: rgb(var(--gray));
				font-size: 1.1rem;
				line-height: 1.7;
			}

			.prose {
				max-width: var(--maxw-prose);
				margin: 0 auto;
				color: rgb(var(--gray-dark));
			}

			/* ── Mermaid diagrams (client-rendered) ── */
			.prose :global(pre.mermaid) {
				/* reset the code-block chrome from global.css */
				background: none;
				border: none;
				padding: 0.5em 0;
				margin: 1.8em 0;
				text-align: center;
				overflow-x: auto;
				/* hide raw source until mermaid swaps in the SVG */
				color: transparent;
				line-height: normal;
			}
			.prose :global(pre.mermaid[data-processed='true']) {
				color: inherit;
			}
			.prose :global(pre.mermaid svg) {
				max-width: 100%;
				height: auto;
			}
			/* clickable affordance once rendered */
			.prose :global(pre.mermaid[data-processed='true']) {
				position: relative;
				cursor: zoom-in;
			}
			.prose :global(pre.mermaid[data-processed='true']::after) {
				content: '🔍 클릭하면 확대';
				position: absolute;
				top: 0.4em;
				right: 0.4em;
				padding: 0.25em 0.65em;
				font-size: 0.72rem;
				line-height: 1;
				color: rgb(var(--gray-dark));
				background: rgba(255, 255, 255, 0.85);
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
				opacity: 0;
				transition: opacity 0.15s ease;
				pointer-events: none;
			}
			.prose :global(pre.mermaid[data-processed='true']:hover::after),
			.prose :global(pre.mermaid[data-processed='true']:focus-visible::after) {
				opacity: 1;
			}

			/* ── Content images: click-to-zoom affordance ── */
			.prose :global(img) {
				cursor: zoom-in;
			}

			/* ── Lightbox overlay (diagrams + images) ── */
			:global(.lightbox) {
				position: fixed;
				inset: 0;
				z-index: 1000;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: clamp(1rem, 4vw, 3rem);
				background: rgba(15, 18, 22, 0.78);
				-webkit-backdrop-filter: blur(2px);
				backdrop-filter: blur(2px);
				opacity: 0;
				transition: opacity 0.18s ease;
				overscroll-behavior: contain;
			}
			:global(.lightbox.is-open) {
				opacity: 1;
			}
			:global(.lightbox__stage) {
				max-width: 96vw;
				max-height: 92vh;
				overflow: auto;
				background: #fff;
				border-radius: 12px;
				box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
				padding: clamp(1rem, 3vw, 2.2rem);
				-webkit-overflow-scrolling: touch;
			}
			:global(.lightbox__content) {
				margin: 0 auto;
				transition: width 0.12s ease;
			}
			:global(.lightbox__content svg),
			:global(.lightbox__content img) {
				display: block;
				width: 100%;
				height: auto;
			}
			/* zoom toolbar */
			:global(.lightbox__toolbar) {
				position: fixed;
				bottom: clamp(0.9rem, 3vw, 1.8rem);
				left: 50%;
				transform: translateX(-50%);
				display: flex;
				align-items: center;
				gap: 0.25rem;
				padding: 0.3rem 0.45rem;
				background: rgba(28, 32, 38, 0.92);
				border: 1px solid rgba(255, 255, 255, 0.18);
				border-radius: 999px;
				box-shadow: 0 6px 24px rgba(0, 0, 0, 0.4);
			}
			:global(.lightbox__btn) {
				width: 40px;
				height: 40px;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.3rem;
				line-height: 1;
				color: #fff;
				background: transparent;
				border: none;
				border-radius: 50%;
				cursor: pointer;
				transition: background 0.15s ease;
			}
			:global(.lightbox__btn:hover) {
				background: rgba(255, 255, 255, 0.16);
			}
			:global(.lightbox__btn:disabled) {
				opacity: 0.35;
				cursor: default;
			}
			:global(.lightbox__zoomlabel) {
				min-width: 3.6em;
				text-align: center;
				font-size: 0.85rem;
				color: rgba(255, 255, 255, 0.9);
				font-variant-numeric: tabular-nums;
				user-select: none;
			}
			:global(.lightbox__close) {
				position: fixed;
				top: clamp(0.75rem, 2vw, 1.5rem);
				right: clamp(0.75rem, 2vw, 1.5rem);
				width: 44px;
				height: 44px;
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 1.5rem;
				line-height: 1;
				color: #fff;
				background: rgba(255, 255, 255, 0.14);
				border: 1px solid rgba(255, 255, 255, 0.4);
				border-radius: 50%;
				cursor: pointer;
				transition: background 0.15s ease;
			}
			:global(.lightbox__close:hover) {
				background: rgba(255, 255, 255, 0.28);
			}

			@media (max-width: 720px) {
				.hero-banner {
					height: clamp(200px, 46vw, 300px);
				}
				.hero-inner {
					padding: 1.5em 1.15em;
				}
				.title {
					margin-bottom: 1.4em;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		{
			heroImage && (
				<section class="hero-banner">
					<Image width={1920} height={1080} src={heroImage} alt={title} />
					<div class="hero-scrim" />
					<div class="hero-overlay">
						<div class="hero-inner">
							<div class="meta">
								<FormattedDate date={pubDate} />
								{updatedDate && (
									<>
										<span class="dot" />
										<span class="last-updated-on">
											수정 <FormattedDate date={updatedDate} />
										</span>
									</>
								)}
							</div>
							<h1>{title}</h1>
							<TagList tags={tags} />
						</div>
					</div>
				</section>
			)
		}
		<main>
			<article>
				{
					!heroImage && (
						<header class="title">
							<div class="meta">
								<FormattedDate date={pubDate} />
								{updatedDate && (
									<>
										<span class="dot" />
										<span class="last-updated-on">
											수정 <FormattedDate date={updatedDate} />
										</span>
									</>
								)}
							</div>
							<h1>{title}</h1>
							<TagList tags={tags} />
						</header>
					)
				}
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			import mermaid from 'mermaid';

			const blocks = () =>
				Array.from(document.querySelectorAll('pre.mermaid'));

			async function renderMermaid() {
				const nodes = blocks();
				if (nodes.length === 0) return;
				mermaid.initialize({
					startOnLoad: false,
					theme: 'neutral',
					securityLevel: 'strict',
					fontFamily:
						"Pretendard, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
				});
				try {
					await mermaid.run({ nodes });
					setupLightbox();
				} catch (err) {
					console.error('[mermaid] render failed', err);
				}
			}

			// ── Lightbox: click a diagram or image → zoomable overlay ──
			let overlay: HTMLDivElement | null = null;

			function closeLightbox() {
				if (!overlay) return;
				overlay.classList.remove('is-open');
				document.body.style.overflow = '';
				const el = overlay;
				overlay = null;
				window.setTimeout(() => el.remove(), 180);
			}

			function makeBtn(glyph: string, label: string, zoomKey: string) {
				const b = document.createElement('button');
				b.type = 'button';
				b.className = 'lightbox__btn';
				b.setAttribute('aria-label', label);
				b.title = label;
				b.dataset.zoom = zoomKey;
				b.textContent = glyph;
				return b;
			}

			function openLightbox(source: SVGElement | HTMLImageElement) {
				closeLightbox();
				overlay = document.createElement('div');
				overlay.className = 'lightbox';
				overlay.setAttribute('role', 'dialog');
				overlay.setAttribute('aria-modal', 'true');
				overlay.setAttribute('aria-label', '확대 보기');

				const stage = document.createElement('div');
				stage.className = 'lightbox__stage';
				const content = document.createElement('div');
				content.className = 'lightbox__content';

				let node: SVGElement | HTMLImageElement;
				if (source instanceof HTMLImageElement) {
					const img = document.createElement('img');
					img.src = source.currentSrc || source.src;
					img.alt = source.alt || '';
					node = img;
				} else {
					const clone = source.cloneNode(true) as SVGElement;
					// drop inline sizing so it can grow freely
					clone.removeAttribute('style');
					clone.removeAttribute('width');
					clone.removeAttribute('height');
					node = clone;
				}
				content.appendChild(node);
				stage.appendChild(content);

				// zoom toolbar
				const toolbar = document.createElement('div');
				toolbar.className = 'lightbox__toolbar';
				const zoomOut = makeBtn('−', '축소', 'out');
				const zoomLabel = document.createElement('span');
				zoomLabel.className = 'lightbox__zoomlabel';
				const zoomIn = makeBtn('+', '확대', 'in');
				const reset = makeBtn('⤢', '원래 크기', 'reset');
				toolbar.append(zoomOut, zoomLabel, zoomIn, reset);

				const close = document.createElement('button');
				close.type = 'button';
				close.className = 'lightbox__close';
				close.setAttribute('aria-label', '닫기');
				close.textContent = '✕';

				overlay.append(stage, toolbar, close);
				document.body.appendChild(overlay);
				document.body.style.overflow = 'hidden';

				// ── zoom state (scales the content width; stage scrolls) ──
				const MIN = 0.5;
				const MAX = 5;
				const STEP = 1.25;
				let scale = 1;
				let baseWidth = 0;

				function measureBase() {
					const cs = getComputedStyle(stage);
					const inner =
						stage.clientWidth -
						parseFloat(cs.paddingLeft) -
						parseFloat(cs.paddingRight);
					let natural = 0;
					if (node instanceof HTMLImageElement) {
						natural = node.naturalWidth || inner;
					} else {
						natural = node.getBoundingClientRect().width || inner;
					}
					// 100% = fit-to-stage (or natural size if it's smaller)
					baseWidth = Math.min(natural, inner) || inner;
				}

				function apply() {
					content.style.width = Math.round(baseWidth * scale) + 'px';
					zoomLabel.textContent = Math.round(scale * 100) + '%';
					zoomOut.disabled = scale <= MIN + 0.001;
					zoomIn.disabled = scale >= MAX - 0.001;
				}

				function zoom(factor: number) {
					scale = Math.min(MAX, Math.max(MIN, scale * factor));
					apply();
				}

				measureBase();
				apply();

				zoomIn.addEventListener('click', (e) => {
					e.stopPropagation();
					zoom(STEP);
				});
				zoomOut.addEventListener('click', (e) => {
					e.stopPropagation();
					zoom(1 / STEP);
				});
				reset.addEventListener('click', (e) => {
					e.stopPropagation();
					scale = 1;
					apply();
				});

				// re-measure once an <img> has loaded its natural size
				if (node instanceof HTMLImageElement && !node.complete) {
					node.addEventListener(
						'load',
						() => {
							measureBase();
							apply();
						},
						{ once: true },
					);
				}

				// close on backdrop click / close button
				overlay.addEventListener('click', (e) => {
					if (e.target === overlay) closeLightbox();
				});
				close.addEventListener('click', closeLightbox);

				// ctrl/⌘ + wheel to zoom
				stage.addEventListener(
					'wheel',
					(e) => {
						if (!e.ctrlKey && !e.metaKey) return;
						e.preventDefault();
						zoom(e.deltaY < 0 ? STEP : 1 / STEP);
					},
					{ passive: false },
				);

				// force reflow so the opacity transition plays
				void overlay.offsetWidth;
				overlay.classList.add('is-open');
				close.focus();
			}

			function wireTrigger(
				el: HTMLElement,
				getSource: () => SVGElement | HTMLImageElement | null,
			) {
				if (el.dataset.lightbox === 'on') return;
				el.dataset.lightbox = 'on';
				el.setAttribute('role', 'button');
				el.setAttribute('tabindex', '0');
				const activate = () => {
					const src = getSource();
					if (src) openLightbox(src);
				};
				el.addEventListener('click', activate);
				el.addEventListener('keydown', (e) => {
					if (e.key === 'Enter' || e.key === ' ') {
						e.preventDefault();
						activate();
					}
				});
			}

			function setupLightbox() {
				document
					.querySelectorAll<HTMLElement>("pre.mermaid[data-processed='true']")
					.forEach((pre) => {
						pre.setAttribute('aria-label', '다이어그램 확대 보기 (클릭)');
						wireTrigger(pre, () => pre.querySelector('svg'));
					});
				document
					.querySelectorAll<HTMLImageElement>('.prose img')
					.forEach((img) => {
						img.setAttribute(
							'aria-label',
							(img.alt ? img.alt + ' — ' : '') + '이미지 확대 보기 (클릭)',
						);
						wireTrigger(img, () => img);
					});
			}

			document.addEventListener('keydown', (e) => {
				if (e.key === 'Escape') {
					closeLightbox();
					return;
				}
				if (!overlay) return;
				let key: string | null = null;
				if (e.key === '+' || e.key === '=') key = 'in';
				else if (e.key === '-' || e.key === '_') key = 'out';
				else if (e.key === '0') key = 'reset';
				if (key) {
					e.preventDefault();
					overlay
						.querySelector<HTMLButtonElement>(`.lightbox__btn[data-zoom="${key}"]`)
						?.click();
				}
			});

			function init() {
				setupLightbox(); // wire images immediately (independent of mermaid)
				renderMermaid(); // render diagrams, then re-wire them
			}

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', init, { once: true });
			} else {
				init();
			}
		</script>
	</body>
</html>
