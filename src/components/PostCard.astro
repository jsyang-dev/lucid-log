---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../consts';
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';

interface Props {
	post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, pubDate, heroImage, tags } = post.data;
const href = withBase(`/blog/${post.id}/`);
---

<article class="post-card">
	<div class="body">
		<p class="date">
			<FormattedDate date={pubDate} />
		</p>
		<h2 class="title">
			<a href={href}>{title}</a>
		</h2>
		{description && <p class="desc">{description}</p>}
		<TagList tags={tags} />
	</div>
	{
		heroImage && (
			<a class="thumb" href={href} tabindex="-1" aria-hidden="true">
				<Image width={360} height={270} src={heroImage} alt="" />
			</a>
		)
	}
</article>

<style>
	.post-card {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		gap: 1.4em;
	}
	.body {
		flex: 1 1 auto;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.55em;
		order: 1;
	}
	/* Small fixed thumbnail (list/index/tag views only) */
	.thumb {
		order: 2;
		flex: 0 0 auto;
		width: 168px;
		aspect-ratio: 4 / 3;
		display: block;
		overflow: hidden;
		border-radius: var(--radius);
		background: rgb(var(--surface-2));
	}
	.thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.4s ease;
	}
	.thumb:hover :global(img) {
		transform: scale(1.04);
	}
	.date {
		margin: 0;
		font-size: 0.82rem;
		letter-spacing: 0.02em;
		color: rgb(var(--gray));
	}
	.title {
		margin: 0;
		font-size: 1.35rem;
		line-height: 1.35;
	}
	.title a {
		color: rgb(var(--black));
		text-decoration: none;
	}
	.title a:hover {
		color: rgb(var(--accent));
	}
	.desc {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
		line-height: 1.65;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.post-card .tags {
		margin-top: 0.15em;
	}
	@media (max-width: 560px) {
		.post-card {
			gap: 1em;
		}
		.thumb {
			width: 96px;
			border-radius: 10px;
		}
		.title {
			font-size: 1.15rem;
		}
		.desc {
			-webkit-line-clamp: 2;
		}
	}
</style>
