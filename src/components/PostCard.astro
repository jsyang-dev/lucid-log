---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../consts';
import FormattedDate from './FormattedDate.astro';
import TagList from './TagList.astro';

interface Props {
	post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, pubDate, heroImage, tags } = post.data;
const href = withBase(`/blog/${post.id}/`);
---

<article class="post-card">
	{
		heroImage && (
			<a class="thumb" href={href} tabindex="-1" aria-hidden="true">
				<Image width={840} height={472} src={heroImage} alt="" />
			</a>
		)
	}
	<div class="body">
		<p class="date">
			<FormattedDate date={pubDate} />
		</p>
		<h2 class="title">
			<a href={href}>{title}</a>
		</h2>
		{description && <p class="desc">{description}</p>}
		<TagList tags={tags} />
	</div>
</article>

<style>
	.post-card {
		display: flex;
		flex-direction: column;
		gap: 1em;
	}
	.thumb {
		display: block;
		overflow: hidden;
		border-radius: var(--radius);
		aspect-ratio: 16 / 9;
		background: rgb(var(--surface-2));
	}
	.thumb :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.4s ease;
	}
	.thumb:hover :global(img) {
		transform: scale(1.03);
	}
	.body {
		display: flex;
		flex-direction: column;
		gap: 0.55em;
	}
	.date {
		margin: 0;
		font-size: 0.82rem;
		letter-spacing: 0.02em;
		color: rgb(var(--gray));
	}
	.title {
		margin: 0;
		font-size: 1.5rem;
		line-height: 1.35;
	}
	.title a {
		color: rgb(var(--black));
		text-decoration: none;
	}
	.title a:hover {
		color: rgb(var(--accent));
	}
	.desc {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.98rem;
		line-height: 1.65;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.post-card .tags {
		margin-top: 0.15em;
	}
	@media (max-width: 720px) {
		.title {
			font-size: 1.3rem;
		}
	}
</style>
